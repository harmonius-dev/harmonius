{
  "enabledPlugins": {
    "harmonize@cjhowe-us-workflow": true,
    "rumdl@cjhowe-us-workflow": true
  },
  "extraKnownMarketplaces": {
    "cjhowe-us-workflow": {
      "source": {
        "repo": "cjhowe-us/workflow",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/check-rust-stop.sh",
            "timeout": 60,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/run-xcodegen-stop.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ]
  }
}
