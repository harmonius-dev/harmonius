{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "artifact-documents@cjhowe-us-marketplace": true,
    "artifact-github@cjhowe-us-marketplace": true,
    "artifact@cjhowe-us-marketplace": true,
    "rumdl@cjhowe-us-marketplace": true,
    "workflow@cjhowe-us-marketplace": true
  },
  "extraKnownMarketplaces": {
    "cjhowe-us-marketplace": {
      "source": {
        "repo": "cjhowe-us/marketplace",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/verify.sh",
            "timeout": 90,
            "type": "command"
          }
        ]
      }
    ]
  }
}
