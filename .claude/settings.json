{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/fmt-markdown.sh",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": ".claude/hooks/check-rust.sh",
            "timeout": 120,
            "type": "command"
          },
          {
            "command": ".claude/hooks/check-python.sh",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": ".claude/hooks/check-swift.sh",
            "timeout": 60,
            "type": "command"
          },
          {
            "command": ".claude/hooks/check-config.sh",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": ".claude/hooks/run-xcodegen.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ]
  }
}
