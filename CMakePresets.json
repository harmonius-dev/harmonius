{
  "buildPresets": [
    {
      "configurePreset": "macos-debug",
      "name": "macos-debug"
    },
    {
      "configurePreset": "macos-release",
      "name": "macos-release"
    },
    {
      "configurePreset": "macos-relwithdebinfo",
      "name": "macos-relwithdebinfo"
    },
    {
      "configurePreset": "linux-debug",
      "name": "linux-debug"
    },
    {
      "configurePreset": "linux-release",
      "name": "linux-release"
    },
    {
      "configurePreset": "windows-debug-d3d12",
      "name": "windows-debug-d3d12"
    },
    {
      "configurePreset": "windows-release-d3d12",
      "name": "windows-release-d3d12"
    },
    {
      "configurePreset": "windows-debug-vulkan",
      "name": "windows-debug-vulkan"
    },
    {
      "configurePreset": "windows-release-vulkan",
      "name": "windows-release-vulkan"
    }
  ],
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MAKE_PROGRAM": "ninja"
      },
      "environment": {
        "VCPKG_FEATURE_FLAGS": "-registries"
      },
      "generator": "Ninja",
      "hidden": true,
      "name": "base",
      "toolchainFile": "${sourceDir}/vendor/vcpkg/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "cacheVariables": {
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
        "CMAKE_CXX_STDLIB_MODULES_JSON":
          "/opt/homebrew/opt/llvm/lib/c++/libc++.modules.json",
        "CMAKE_OSX_SYSROOT":
          "/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk",
        "HARMONIUS_GPU_BACKEND": "metal",
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      },
      "hidden": true,
      "inherits": "base",
      "name": "macos-base"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "displayName": "macOS Debug (Metal)",
      "inherits": "macos-base",
      "name": "macos-debug"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
      },
      "displayName": "macOS Release (Metal)",
      "inherits": "macos-base",
      "name": "macos-release"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
      },
      "displayName": "macOS RelWithDebInfo (Metal)",
      "inherits": "macos-base",
      "name": "macos-relwithdebinfo"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HARMONIUS_GPU_BACKEND": "vulkan",
        "VCPKG_MANIFEST_FEATURES": "vulkan",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      },
      "displayName": "Linux Debug (Vulkan)",
      "inherits": "base",
      "name": "linux-debug"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "HARMONIUS_GPU_BACKEND": "vulkan",
        "VCPKG_MANIFEST_FEATURES": "vulkan",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      },
      "displayName": "Linux Release (Vulkan)",
      "inherits": "base",
      "name": "linux-release"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HARMONIUS_GPU_BACKEND": "d3d12",
        "VCPKG_MANIFEST_FEATURES": "d3d12",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      },
      "displayName": "Windows Debug (D3D12)",
      "inherits": "base",
      "name": "windows-debug-d3d12"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "HARMONIUS_GPU_BACKEND": "d3d12",
        "VCPKG_MANIFEST_FEATURES": "d3d12",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      },
      "displayName": "Windows Release (D3D12)",
      "inherits": "base",
      "name": "windows-release-d3d12"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HARMONIUS_GPU_BACKEND": "vulkan",
        "VCPKG_MANIFEST_FEATURES": "vulkan",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      },
      "displayName": "Windows Debug (Vulkan)",
      "inherits": "base",
      "name": "windows-debug-vulkan"
    },
    {
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "HARMONIUS_GPU_BACKEND": "vulkan",
        "VCPKG_MANIFEST_FEATURES": "vulkan",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      },
      "displayName": "Windows Release (Vulkan)",
      "inherits": "base",
      "name": "windows-release-vulkan"
    }
  ],
  "version": 6
}
