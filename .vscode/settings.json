{
  "C_Cpp.intelliSenseEngine": "disabled",
  "clangd.enable": false,
  "cmake.configureOnOpen": false,
  "files.associations": {
    "Sources/HarmoniusShaders/*.h": "cpp"
  },
  "files.exclude": {
    "**/.build": true,
    "**/build": true
  },
  "sweetpad.build.xcodeProjectPath": "Harmonius.xcodeproj",
  "sweetpad.xcodegen.autogenerate": false,
  "swift.autoGenerateLaunchConfigurations": false,
  "swift.sourcekit-lsp.backgroundIndexing": "on",
  "swift.sourcekit-lsp.serverPath": "${workspaceFolder}/scripts/sourcekit-lsp.sh",
  "swift.sourcekit-lsp.supported-languages": [
    "swift",
    "c",
    "cpp",
    "objective-c",
    "objective-cpp"
  ]
}
