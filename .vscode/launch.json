{
  "configurations": [
    {
      "cwd": "${workspaceFolder}",
      "name": "Debug macOS App",
      "preLaunchTask": "dev:debug:macos",
      "program": "${workspaceFolder}/build/debug-macos-app/Contents/MacOS/HarmoniusApp",
      "request": "launch",
      "type": "lldb"
    },
    {
      "cwd": "${workspaceFolder}",
      "name": "Debug iOS Simulator App",
      "pid": "${command:pickProcess}",
      "preLaunchTask": "dev:debug:ios-simulator",
      "request": "attach",
      "type": "lldb"
    },
    {
      "args": [
        "HarmoniusUnitTests"
      ],
      "cwd": "${workspaceFolder}",
      "name": "Debug SwiftPM Unit Tests",
      "preLaunchTask": "spm:build-tests",
      "program": "${workspaceFolder}/build/debug-swiftpm-tests",
      "request": "launch",
      "type": "lldb"
    },
    {
      "args": [
        "HarmoniusAppiumTests"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "APPIUM_SERVER_URL": "http://127.0.0.1:4723",
        "HARMONIUS_APPIUM_APP": "${workspaceFolder}/build/debug-macos-app",
        "HARMONIUS_APPIUM_PLATFORM": "macos"
      },
      "name": "Debug Swift Appium Tests",
      "preLaunchTask": "debug:appium-tests-prep",
      "program": "${workspaceFolder}/build/debug-swiftpm-tests",
      "request": "launch",
      "type": "lldb"
    }
  ],
  "version": "0.2.0"
}
