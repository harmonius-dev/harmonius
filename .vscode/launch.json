{
  "configurations": [
    {
      "cwd": "${workspaceFolder}",
      "name": "HarmoniusApp (macOS)",
      "osx": {
        "program": "build/xcodegen/Build/Products/Debug/HarmoniusApp.app/Contents/MacOS/HarmoniusApp",
        "request": "launch",
        "type": "lldb"
      },
      "preLaunchTask": "xcode:build-app",
      "request": "launch",
      "type": "lldb"
    },
    {
      "cwd": "${workspaceFolder}",
      "name": "HarmoniusUnitTests",
      "osx": {
        "args": [
          "build/xcodegen/Build/Products/Debug/HarmoniusApp.app/Contents/PlugIns/HarmoniusUnitTests.xctest"
        ],
        "env": {
          "DYLD_FRAMEWORK_PATH": "/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/Library/Frameworks:/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/Library/PrivateFrameworks",
          "TEST_HOST": "build/xcodegen/Build/Products/Debug/HarmoniusApp.app/Contents/MacOS/HarmoniusApp"
        },
        "program": "/Applications/Xcode.app/Contents/Developer/usr/bin/xctest",
        "request": "launch",
        "type": "lldb"
      },
      "preLaunchTask": "xcode:build-for-testing",
      "request": "launch",
      "type": "lldb"
    },
    {
      "cwd": "${workspaceFolder}",
      "name": "HarmoniusUITests",
      "osx": {
        "program": "build/xcodegen/Build/Products/Debug/HarmoniusUITests-Runner.app/Contents/MacOS/HarmoniusUITests-Runner",
        "request": "launch",
        "type": "lldb"
      },
      "preLaunchTask": "xcode:build-for-testing",
      "request": "launch",
      "type": "lldb"
    }
  ],
  "version": "0.2.0"
}
